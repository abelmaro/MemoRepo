# Random local bearer used to unlock the dashboard and authorize the control API.
# Use a 43-128-character URL-safe value generated from at least 32 random bytes. Example: openssl rand -hex 32
# The dashboard keeps this token only in sessionStorage for the current browser tab.
MEMOREPO_CONTROL_TOKEN=

# Optional GitHub personal access token. When set, it takes priority over OAuth and the dashboard
# will not request GitHub login. Leave empty to use MemoRepo's OAuth Device Flow.
GH_TOKEN=

# Local state root for SQLite, managed clones, indexes, logs, temporary files, and helper scripts.
# For regular use, prefer a path outside this repository.
MEMOREPO_HOME=./.memorepo

# Localhost ports exposed by Docker Compose.
API_PORT=8787
WEB_PORT=5173

# Docker container name used by generated stdio MCP configs.
# Keep this aligned with docker-compose.yml service container_name.
MEMOREPO_API_CONTAINER_NAME=memorepo-api

# Initial Ask this Space provider/model. Both are runtime-selectable from the dashboard.
MEMOREPO_AGENT_PROVIDER_ID=openai-codex
MEMOREPO_AGENT_MODEL_ID=gpt-5.4

# Per-answer safety budgets. Increase them for large cross-repository investigations when needed.
MEMOREPO_AGENT_MAX_RUN_SECONDS=600
MEMOREPO_AGENT_MAX_TOOL_CALLS=96

# codebase-memory-mcp release downloaded into the API Docker image.
CODEBASE_MEMORY_MCP_VERSION=v0.9.0
CODEBASE_MEMORY_MCP_SHA256_AMD64=8459d5c9d1457f2c82de3de307ffc7641ecbba2dde893427be1e62eca8ef9b25
CODEBASE_MEMORY_MCP_SHA256_ARM64=b0a43fdaf534073c16707d72726b73b149d4c1212034b281ee8b7b2dac755107

# Local maintenance defaults used by the dashboard.
MEMOREPO_SNAPSHOT_RETENTION=3
MEMOREPO_JOB_RETENTION_DAYS=30

# Background job parallelism. Repository-specific jobs still serialize per managed repository.
MEMOREPO_JOB_CONCURRENCY=2

# Per-IP request limits for the local HTTP boundary. Defaults are per 60-second window.
MEMOREPO_RATE_LIMIT_WINDOW_MS=60000
MEMOREPO_AUTH_RATE_LIMIT_MAX=10
MEMOREPO_API_READ_RATE_LIMIT_MAX=300
MEMOREPO_API_WRITE_RATE_LIMIT_MAX=30
MEMOREPO_API_SSE_RATE_LIMIT_MAX=30
MEMOREPO_MCP_RATE_LIMIT_MAX=120
