---
import { withBase } from "../../site.config.mjs";
import { siteContent } from "../content/site";
import Icon from "./Icon.astro";

const { architecture } = siteContent;
const nodeIcons = ["repositories", "connect", "snapshot", "space", "graph", "gateway", "agent"] as const;
---

<figure class="architecture-figure" aria-labelledby="architecture-title architecture-caption">
  <div class="architecture-flow" aria-hidden="true">
    <span class="architecture-flow__boundary">
      <strong>{architecture.boundaryLabel}</strong>
      <small>{architecture.boundarySupport}</small>
    </span>
    <ol>
      {architecture.nodes.map((node, index) => (
        <li class:list={[{ "is-inside": node.boundary === "inside" }]} data-motion-item>
          <span class="architecture-flow__index">{String(index + 1).padStart(2, "0")}</span>
          <span class:list={["architecture-flow__icon", { "architecture-flow__icon--brand": index === 3 }]}>
            {index === 3 ? (
              <img src={withBase("/android-chrome-192x192.png")} width="192" height="192" alt="" />
            ) : (
              <Icon name={nodeIcons[index] ?? "graph"} size={25} />
            )}
          </span>
          <strong>{node.label}</strong>
        </li>
      ))}
    </ol>
  </div>

  <figcaption id="architecture-caption">
    {architecture.statements.map((statement) => <p data-motion-item>{statement}</p>)}
  </figcaption>
  <p class="sr-only"><strong>{architecture.textAlternativeLabel}:</strong> {architecture.textAlternative}</p>
</figure>
