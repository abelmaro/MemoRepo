    "react-dom": "^19.1.1",
    "vite": "^7.1.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
