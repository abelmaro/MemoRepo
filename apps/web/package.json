{
  "name": "@memorepo/web",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "pnpm check:tokens && tsc -p tsconfig.json && vite build",
